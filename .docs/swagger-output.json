{
  "openapi": "3.0.0",
  "info": {
    "title": "Minha API Express + TypeScript",
    "description": "Documentação automática centralizada e higienizada.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000/"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "description": "",
        "responses": {
          "201": {
            "description": "Created"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": {
                    "example": "any"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/penalties": {
      "post": {
        "description": "",
        "responses": {
          "400": {
            "description": "Bad Request"
          }
        },
        "requestBody": {
          "required": true,
          "description": "Penalty data to register",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PenaltySchema"
              }
            },
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/PenaltySchema"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PenaltySchema": {
        "type": "object",
        "required": [
          "username",
          "plate",
          "reason"
        ],
        "properties": {
          "username": {
            "type": "string",
            "example": "John Doe"
          },
          "plate": {
            "type": "string",
            "example": "ABC1D23"
          },
          "reason": {
            "type": "string",
            "example": "Speeding ticket"
          }
        }
      }
    }
  }
}